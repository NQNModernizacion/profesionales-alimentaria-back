NODE_ENV=production
PORT=3000
API_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://nest_template_user:nest_template_password@postgres:5432/nest_template
REDIS_URL=redis://redis:6379

ADMIN_API_URL=http://admin.local/api
ADMIN_JWT_SECRET=clave-secreta-compartida
ADMIN_JWT_ALGORITHM=HS256

# JWT emitidos por este backend (ver CLAUDE.md)
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# JWT_LIFETIME_PROFILE=default
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

BOOTSTRAP_ADMIN_EMAIL=admin@ejemplo.com

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

FLUSH_INTERVAL_MS=5000
FLUSH_BATCH_SIZE=500

ADMIN_DATABASE_URL=mysql://root@host.docker.internal:3306/admin
